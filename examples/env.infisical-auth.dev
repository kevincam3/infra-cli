# Infisical machine-identity credentials for dev secret export.
# Sourced by `infra` when running `infra start --env dev`.
#
# Use dev-scoped machine identities here — these should only have read access
# to dev secrets. Never put prod credentials in this file.
#
# DO NOT COMMIT — make sure ".env.infisical-auth.*" is in your .gitignore.

INFISICAL_HOST=https://infisical.example.com
INFISICAL_PROJECT_ID=your-project-id

# One CLIENT_ID / CLIENT_SECRET pair per machine identity referenced in your
# SECRETS_* arrays in infra.config.sh. Example:
#
# TRAEFIK_CLIENT_ID=
# TRAEFIK_CLIENT_SECRET=
#
# TOOLING_MYSQL_CLIENT_ID=
# TOOLING_MYSQL_CLIENT_SECRET=
